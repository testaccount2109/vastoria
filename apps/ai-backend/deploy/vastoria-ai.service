[Unit]
Description=Vastoria AI Backend (Ollama)
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
WorkingDirectory=%h/vastoria/apps/ai-backend
EnvironmentFile=%h/vastoria/apps/ai-backend/.env
ExecStart=%h/vastoria/apps/ai-backend/.venv/bin/uvicorn vastoria_ai.main:app --host 127.0.0.1 --port 18420
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
